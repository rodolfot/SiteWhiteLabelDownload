# Site (white-label — deixe vazio para usar padroes)
NEXT_PUBLIC_SITE_NAME=DownDoor
NEXT_PUBLIC_SITE_TAGLINE=Seu Portal para Videos e Downloads Gratuitos
NEXT_PUBLIC_SITE_DESCRIPTION=Portal premium para streaming e download de series e videos gratuitos em alta qualidade.
NEXT_PUBLIC_CONTACT_EMAIL=contato@exemplo.com
NEXT_PUBLIC_SITE_URL=https://example.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-site-key
TURNSTILE_SECRET_KEY=your-secret-key

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-id

# Google AdSense (opcional — sem configurar, mostra placeholder)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_ID=
NEXT_PUBLIC_ADSENSE_NATIVE_SLOT_ID=

# Admin credentials (for initial setup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
