# Copie este arquivo para secrets.yaml e preencha os valores em base64
# Para codificar: echo -n "valor" | base64
# NUNCA commite o secrets.yaml real — apenas este .example
apiVersion: v1
kind: Secret
metadata:
  name: downdoor-secrets
type: Opaque
data:
  NEXT_PUBLIC_SUPABASE_URL: <base64>
  NEXT_PUBLIC_SUPABASE_ANON_KEY: <base64>
  SUPABASE_SERVICE_ROLE_KEY: <base64>
  NEXT_PUBLIC_TURNSTILE_SITE_KEY: <base64>
  TURNSTILE_SECRET_KEY: <base64>
  NEXT_PUBLIC_SITE_URL: <base64>
  NEXT_PUBLIC_SENTRY_DSN: <base64>
  NEXT_PUBLIC_GA_MEASUREMENT_ID: <base64>
